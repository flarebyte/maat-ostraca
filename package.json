  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flarebyte/maat-ostraca.git"
  },
  "license": "MIT",
  "author": "Olivier Huin (http://flarebyte.com/)",
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "doc"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "cli": "tsx src/cli.mts",
    "test": "node --import tsx --test",
    "test:cov": "c8 --reporter=text-summary --reporter=lcov node --import tsx --test"
  },
  "devDependencies": {
    "c8": "^11.0.0",
